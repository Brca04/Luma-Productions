# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Settings -> API). These are inlined into the static build, so they
# must also be set as build environment variables in Cloudflare Pages.
#
# Both are safe to expose publicly: the anon key only lets the browser INVOKE
# the "contact" Edge Function. It cannot read the submissions table (RLS).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
